@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://example.org/dictionary#location-search_street-including--reduced-mobility> a skos:Concept ;
    skos:definition "the minimum information required for identifying the location of on-street or off-street places designated for parking vehicles."@en ;
